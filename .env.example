NEXT_PUBLIC_SITE_URL=https://knowplain.com
NEXT_PUBLIC_EMPOWER_URL=https://empower.sjv.io/7XDD2Q
NEXT_PUBLIC_AMAZON_TAG=explainstudio-20

# Phase 2 — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email (Resend). If ANY of these are unset, the checkup still captures the lead but
# tells the user "Saved", not "Sent" — it never claims an email it didn't send.
# KNOWPLAIN_CONTACT_EMAIL and KNOWPLAIN_POSTAL_ADDRESS are CAN-SPAM requirements
# (working opt-out + physical postal address); sending without them is unlawful.
RESEND_API_KEY=
RESEND_FROM="Know Plain <hello@knowplain.com>"
KNOWPLAIN_CONTACT_EMAIL=hello@knowplain.com
KNOWPLAIN_POSTAL_ADDRESS=
# Reversible product releases. Omit for the safe default (enabled); set to false to roll back.
NEXT_PUBLIC_KNOWPLAIN_LOCAL_TOOL_SCENARIOS=true
NEXT_PUBLIC_KNOWPLAIN_CHECKUP_ESTIMATE_LABELS=true
